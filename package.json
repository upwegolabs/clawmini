{
  "name": "clawmini",
  "version": "0.0.1",
  "type": "module",
  "bin": {
    "clawmini": "./dist/cli/index.mjs"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsdown",
    "dev:cli": "tsdown --watch",
    "dev:daemon": "tsdown --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run"
  },
  "dependencies": {
    "@trpc/client": "^11.10.0",
    "@trpc/server": "^11.10.0",
    "commander": "^14.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.3.0",
    "prettier": "^3.8.1",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
